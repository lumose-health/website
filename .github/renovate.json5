{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "baseBranches": ["main"],
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "branchPrefix": "renovate/",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on saturday"]
  },
  "labels": ["dependencies"],
  "ignorePaths": ["**/node_modules/**"],
  "timezone": "America/New_York",
  "schedule": ["at any time"],
  "dependencyDashboardFooter": "Note: `typescript` updates are capped to the range the installed @typescript-eslint packages support (see the typescript packageRule in `.github/renovate.json5`). The typescript-cap-check workflow opens an issue when the cap can be lifted.",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Auto-merge all dependency updates (CI gates protect against breakage)",
      "matchPackageNames": ["*"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Label major updates for post-merge auditing",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "prBodyNotes": ["**This is a major version bump.** Check the changelog for breaking changes."]
    },
    {
      "description": "Auto-merge lockfile maintenance",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group TypeScript type definitions",
      "matchPackageNames": ["@types/*"],
      "groupName": "TypeScript type definitions"
    },
    {
      "description": "Group ESLint dependencies",
      "matchPackageNames": ["eslint", "@eslint/*", "eslint-*"],
      "groupName": "ESLint"
    },
    {
      // Pinned to v9 because eslint-plugin-react (bundled via
      // eslint-config-next) does not yet support ESLint v10 -- the
      // upstream rule still calls the removed contextOrFilename.getFilename()
      // API. Re-enable this update once eslint-plugin-react publishes a
      // release that works with ESLint v10.
      "description": "Block ESLint major bumps until eslint-plugin-react supports ESLint v10",
      "matchPackageNames": ["eslint"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      // The @typescript-eslint packages (installed transitively via
      // eslint-config-next) only support typescript inside their declared
      // peer range -- the v7 bump in PR #200 landed outside it and broke
      // ESLint at load repo-wide. Renovate does not consult npm
      // peerDependencies when selecting versions (dry-run verified; nor
      // does constraintsFiltering), so this cap mirrors the installed peer
      // range. The typescript-cap-check workflow opens an issue when the
      // installed peer range widens past this cap; bump the cap to match.
      "description": "Cap typescript to the installed @typescript-eslint peer range; the typescript-cap-check workflow signals when to lift it",
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<6.1.0"
    },
    {
      "description": "Group testing libraries",
      "matchPackageNames": ["jest", "@jest/*", "vitest", "@vitest/*", "@testing-library/*"],
      "groupName": "Testing libraries"
    },
    {
      "description": "Group Tailwind CSS",
      "matchPackageNames": ["tailwindcss", "@tailwindcss/*"],
      "groupName": "Tailwind CSS"
    },
    {
      "description": "Group Recharts + D3",
      "matchPackageNames": ["recharts", "d3-*"],
      "groupName": "Recharts"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      // cloudflare/wrangler-action is the step in deploy.yml / docs-rebuild.yml /
      // ci.yml that publishes the production site (and PR previews) to Cloudflare
      // Pages. A major bump could change CLI flags, output shape, or default
      // behavior in ways that pass CI but silently change deploy behavior.
      // Minor/patch bumps still auto-merge; majors require human review.
      "description": "Require manual review for cloudflare/wrangler-action major bumps",
      "matchPackageNames": ["cloudflare/wrangler-action"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major", "deploy-critical"]
    }
  ]
}
